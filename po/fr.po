msgstr "\"two\""

#: src/ch19-03-pattern-syntax.md:18 src/ch19-03-pattern-syntax.md:106
msgid "\"three\""
msgstr "\"three\""

#: src/ch19-03-pattern-syntax.md:19 src/ch19-03-pattern-syntax.md:107
